# ─────────────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────

# --- API ---
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
LOG_LEVEL=info

# --- Database (Neon PostgreSQL + pgvector) ---
# Pooled connection — used by the app at runtime
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct connection — used by Prisma migrations only
DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth (better-auth) ---
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_URL=http://localhost:4000
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Credential encryption (broker investor passwords, AES-GCM) ---
# 32-byte key, hex-encoded (generate: openssl rand -hex 32)
CREDENTIAL_ENCRYPTION_KEY=change-me-64-hex-characters

# --- MT5 bridge (Python FastAPI) ---
MT5_BRIDGE_URL=http://localhost:8000
MT5_BRIDGE_SHARED_SECRET=change-me-shared-secret
